            "text": "[\n  {\n    \"id\": \"default\",\n    \"name\": \"Default\",\n    \"description\": \"Default glossary\",\n    \"author\": \"self\",\n    \"glossary\": \"default\",\n    \"langs\": [\n      \"auto\"\n    ],\n    \"i18ns\": {\n      \"zh-CN\": {\n        \"name\": \"默认\",\n        \"description\": \"默认术语库\"\n      },\n      \"zh-TW\": {\n        \"name\": \"預設\",\n        \"description\": \"預設術語庫\"\n      },\n      \"en\": {\n        \"name\": \"Default\",\n        \"description\": \"Default glossary\"\n      },\n      \"ja\": {\n        \"name\": \"デフォルト\",\n        \"description\": \"デフォルトの用語集\"\n      },\n      \"ar\": {\n        \"name\": \"افتراضي\",\n        \"description\": \"قائمة المصطلحات الافتراضية\"\n      },\n      \"de\": {\n        \"name\": \"Standard\",\n        \"description\": \"Standard-Glossar\"\n      },\n      \"es\": {\n        \"name\": \"Predeterminado\",\n        \"description\": \"Glosario predeterminado\"\n      },\n      \"fa\": {\n        \"name\": \"پیش‌فرض\",\n        \"description\": \"واژه‌نامه پیش‌فرض\"\n      },\n      \"fr\": {\n        \"name\": \"Défaut\",\n        \"description\": \"Glossaire par défaut\"\n      },\n      \"he\": {\n        \"name\": \"ברירת מחדל\",\n        \"description\": \"מילון מונחים ברירת מחדל\"\n      },\n      \"hi\": {\n        \"name\": \"डिफ़ॉल्ट\",\n        \"description\": \"डिफ़ॉल्ट शब्दावली\"\n      },\n      \"hu\": {\n        \"name\": \"Alapértelmezett\",\n        \"description\": \"Alapértelmezett szószedet\"\n      },\n      \"it\": {\n        \"name\": \"Predefinito\",\n        \"description\": \"Glossario predefinito\"\n      },\n      \"pt-BR\": {\n        \"name\": \"Padrão\",\n        \"description\": \"Glossário padrão\"\n      },\n      \"ru\": {\n        \"name\": \"По умолчанию\",\n        \"description\": \"Глоссарий по умолчанию\"\n      },\n      \"ko\": {\n        \"name\": \"기본값\",\n        \"description\": \"기본 용어집\"\n      },\n      \"pt-PT\": {\n        \"name\": \"Padrão\",\n        \"description\": \"Glossário padrão\"\n      },\n      \"tr\": {\n        \"name\": \"Varsayılan\",\n        \"description\": \"Varsayılan sözlük\"\n      }\n    },\n    \"langsHash\": {\n      \"auto\": \"97ba8425b9c415bfc5814bad997509213e863bc4b0a8cb4b0e8e9ba9d33bb3d3\"\n    }\n  },\n  {\n    \"id\": \"twitter\",\n    \"name\": \"Twitter\",\n    \"description\": \"推特术语库，包含名人等相关术语的中文翻译。\",\n    \"author\": \"immersive\",\n    \"glossary\": \"twitter\",\n    \"langs\": [\n      \"zh-CN\",\n      \"zh-TW\"\n    ],\n    \"i18ns\": {\n      \"zh-CN\": {\n        \"name\": \"推特\",\n        \"description\": \"推特术语库，包含名人等相关术语的中文翻译。\"\n      },\n      \"zh-TW\": {\n        \"name\": \"推特\",\n        \"description\": \"推特術語庫，包含名人等相關術語的中文翻譯。\"\n      },\n      \"en\": {\n        \"name\": \"Twitter\",\n        \"description\": \"Twitter glossary, containing Chinese translations of related terms such as celebrities and social media platforms.\"\n      }\n    },\n    \"matches\": [\n      \"twitter.com\",\n      \"mobile.twitter.com\",\n      \"tweetdeck.twitter.com\",\n      \"pro.twitter.com\",\n      \"https://platform.twitter.com/embed*\",\n      \"x.com\",\n      \"mobile.x.com\",\n      \"tweetdeck.x.com\",\n      \"pro.x.com\",\n      \"https://platform.x.com/embed*\"\n    ],\n    \"langsHash\": {\n      \"zh-CN\": \"032d3f5da97c899c32292506acbee3e40164de76bf0749fecffe5b3f77cb2920\",\n      \"zh-TW\": \"c30687c71525f809057d08c351ccff3c97c9660ad162cc4f17d575375f6ecd1b\"\n    }\n  },\n  {\n    \"id\": \"web3\",\n    \"name\": \"Web3 Expert\",\n    \"description\": \"Specialized in translating Web3 and blockchain content, ensuring accurate and idiomatic translations for cryptocurrency, DeFi, NFT, and blockchain technology terminology.\",\n    \"author\": \"immersive\",\n    \"glossary\": \"web3\",\n    \"langs\": [\n      \"auto\",\n      \"zh-CN\",\n      \"zh-TW\"\n    ],\n    \"i18ns\": {\n      \"zh-CN\": {\n        \"name\": \"Web3\",\n        \"description\": \"Web3术语库，包含加密货币、DeFi、NFT和区块链技术相关术语的中文翻译。\"\n      },\n      \"zh-TW\": {\n        \"name\": \"Web3\",\n        \"description\": \"Web3術語庫，包含加密貨幣、DeFi、NFT和區塊鏈技術相關術語的繁體中文翻譯。\"\n      },\n      \"en\": {\n        \"name\": \"Web3 Expert\",\n        \"description\": \"Specialized in translating Web3 and blockchain content, ensuring accurate and idiomatic translations for cryptocurrency, DeFi, NFT, and blockchain technology terminology.\"\n      },\n      \"ja\": {\n        \"name\": \"Web3エキスパート\",\n        \"description\": \"Web3およびブロックチェーンコンテンツの翻訳を専門とし、暗号通貨、DeFi、NFT、ブロックチェーン技術用語の正確で慣用的な翻訳を保証します。\"\n      },\n      \"ar\": {\n        \"name\": \"خبير Web3\",\n        \"description\": \"متخصص في ترجمة محتوى Web3 و blockchain، مع ضمان ترجمات دقيقة ومناسبة لمصطلحات العملات المشفرة و DeFi و NFT وتقنية blockchain.\"\n      },\n      \"de\": {\n        \"name\": \"Web3-Experte\",\n        \"description\": \"Spezialisiert auf die Übersetzung von Web3- und Blockchain-Inhalten, um genaue und idiomatische Übersetzungen für Kryptowährungs-, DeFi-, NFT- und Blockchain-Technologie-Terminologie zu gewährleisten.\"\n      },\n      \"es\": {\n        \"name\": \"Experto en Web3\",\n        \"description\": \"Especializado en la traducción de contenido de Web3 y blockchain, garantizando traducciones precisas e idiomáticas para la terminología de criptomonedas, DeFi, NFT y tecnología blockchain.\"\n      },\n      \"fa\": {\n        \"name\": \"کارشناس وب۳\",\n        \"description\": \"متخصص در ترجمه محتوای وب۳ و بلاک‌چین، تضمین ترجمه‌های دقیق و اصطلاحی برای اصطلاحات ارزهای دیجیتال، دیفای، ان‌اف‌تی و فناوری بلاک‌چین.\"\n      },\n      \"fr\": {\n        \"name\": \"Expert Web3\",\n        \"description\": \"Spécialisé dans la traduction de contenu Web3 et blockchain, assurant des traductions précises et idiomatiques pour la terminologie des cryptomonnaies, de la DeFi, des NFT et de la technologie blockchain.\"\n      },\n      \"he\": {\n        \"name\": \"מומחה Web3\",\n        \"description\": \"מתמחה בתרגום תוכן Web3 ובלוקצ'יין, תוך הבטחת תרגומים מדויקים ואידיומטיים לטרמינולוגיה של מטבעות קריפטוגרפיים, DeFi, NFT וטכנולוגיית בלוקצ'יין.\"\n      },\n      \"hi\": {\n        \"name\": \"Web3 विशेषज्ञ\",\n        \"description\": \"Web3 और ब्लॉकचेन सामग्री का अनुवाद करने में विशेषज्ञता, क्रिप्टोकरेंसी, DeFi, NFT और ब्लॉकचेन प्रौद्योगिकी शब्दावली के लिए सटीक और मुहावरेदार अनुवाद सुनिश्चित करना।\"\n      },\n      \"hu\": {\n        \"name\": \"Web3 szakértő\",\n        \"description\": \"Web3 és blokklánc tartalmak fordítására szakosodott, biztosítva a kriptovaluta, DeFi, NFT és blokklánc technológiai terminológia pontos és idiomatikus fordítását.\"\n      },\n      \"it\": {\n        \"name\": \"Esperto Web3\",\n        \"description\": \"Specializzato nella traduzione di contenuti Web3 e blockchain, garantendo traduzioni accurate e idiomatiche per la terminologia di criptovaluta, DeFi, NFT e tecnologia blockchain.\"\n      },\n      \"ru\": {\n        \"name\": \"Эксперт Web3\",\n        \"description\": \"Специализируется на переводе контента Web3 и блокчейна, обеспечивая точные и идиоматические переводы для терминологии криптовалют, DeFi, NFT и технологии блокчейн.\"\n      },\n      \"ko\": {\n        \"name\": \"Web3 전문가\",\n        \"description\": \"Web3 및 블록체인 콘텐츠 번역 전문가로서 암호화폐, DeFi, NFT, 블록체인 기술 용어에 대한 정확하고 자연스러운 번역을 보장합니다.\"\n      },\n      \"pt-PT\": {\n        \"name\": \"Especialista em Web3\",\n        \"description\": \"Especializado na tradução de conteúdo Web3 e blockchain, garantindo traduções precisas e idiomáticas para terminologia de criptomoeda, DeFi, NFT e tecnologia blockchain.\"\n      },\n      \"pt-BR\": {\n        \"name\": \"Especialista em Web3\",\n        \"description\": \"Especializado na tradução de conteúdo Web3 e blockchain, garantindo traduções precisas e idiomáticas para terminologia de criptomoeda, DeFi, NFT e tecnologia blockchain.\"\n      },\n      \"tr\": {\n        \"name\": \"Web3 Uzmanı\",\n        \"description\": \"Web3 ve blockchain içeriğinin çevirisinde uzmanlaşmış, kripto para birimi, DeFi, NFT ve blockchain teknolojisi terminolojisi için doğru ve deyimsel çeviriler sağlamaktadır.\"\n      }\n    },\n    \"langsHash\": {\n      \"auto\": \"fa45d0dbfac5ee5e8e65acd221bb1859bcccb93a5205a2d3948ed4ba6ca03b2d\",\n      \"zh-CN\": \"2202a8432c765a9b38d12a48eeb55896631780a4fc665a4b8d78b6cc4026be03\",\n      \"zh-TW\": \"8b2e8558726cc49f523ee83b1810509d370955ce9e2d4cf0247c74017dc761d1\"\n    }\n  },\n  {\n    \"id\": \"tech\",\n    \"name\": \"Technology Expert\",\n    \"description\": \"Focuses on general technology concepts, including hardware, AI models, and major tech companies.\",\n    \"author\": \"immersive\",\n    \"glossary\": \"tech\",\n    \"langs\": [\n      \"auto\",\n      \"zh-CN\",\n      \"zh-TW\"\n    ],\n    \"i18ns\": {\n      \"zh-CN\": {\n        \"name\": \"科技\",\n        \"description\": \"专注于通用科技概念，涵盖硬件、AI 模型和主要科技公司。\"\n      },\n      \"zh-TW\": {\n        \"name\": \"科技\",\n        \"description\": \"專注於通用科技概念，涵蓋硬體、AI 模型和主要科技公司。\"\n      },\n      \"en\": {\n        \"name\": \"Technology Expert\",\n        \"description\": \"Focuses on general technology concepts, including hardware, AI models, and major tech companies.\"\n      },\n      \"ja\": {\n        \"name\": \"テクノロジーエキスパート\",\n        \"description\": \"ハードウェア、AIモデル、主要なテクノロジー企業を含む一般的な技術コンセプトに焦点を当てています。\"\n      },\n      \"ar\": {\n        \"name\": \"خبير تكنولوجيا\",\n        \"description\": \"يركز على مفاهيم التكنولوجيا العامة، بما في ذلك الأجهزة ونماذج الذكاء الاصطناعي وشركات التكنولوجيا الكبرى.\"\n      },\n      \"de\": {\n        \"name\": \"Technologie-Experte\",\n        \"description\": \"Konzentriert sich auf allgemeine Technologiekonzepte, einschließlich Hardware, KI-Modelle und große Technologieunternehmen.\"\n      },\n      \"es\": {\n        \"name\": \"Experto en Tecnología\",\n        \"description\": \"Se centra en conceptos generales de tecnología, incluyendo hardware, modelos de IA y las principales empresas tecnológicas.\"\n      },\n      \"fa\": {\n        \"name\": \"کارشناس فناوری\",\n        \"description\": \"بر مفاهیم کلی فناوری، از جمله سخت‌افزار، مدل‌های هوش مصنوعی و شرکت‌های بزرگ فناوری تمرکز دارد.\"\n      },\n      \"fr\": {\n        \"name\": \"Expert en technologie\",\n        \"description\": \"Se concentre sur les concepts technologiques généraux, y compris le matériel, les modèles d'IA et les grandes entreprises technologiques.\"\n      },\n      \"he\": {\n        \"name\": \"מומחה טכנולוגיה\",\n        \"description\": \"מתמקד במושגי טכנולוגיה כלליים, כולל חומרה, מודלי בינה מלאכותית וחברות טכנולוגיה גדולות.\"\n      },\n      \"hi\": {\n        \"name\": \"प्रौद्योगिकी विशेषज्ञ\",\n        \"description\": \"सामान्य प्रौद्योगिकी अवधारणाओं पर ध्यान केंद्रित करता है, जिसमें हार्डवेयर, एआई मॉडल और प्रमुख तकनीकी कंपनियां शामिल हैं।\"\n      },\n      \"hu\": {\n        \"name\": \"Technológiai szakértő\",\n        \"description\": \"Általános technológiai koncepciókra összpontosít, beleértve a hardvert, az MI-modelleket és a nagy technológiai vállalatokat.\"\n      },\n      \"it\": {\n        \"name\": \"Esperto di Tecnologia\",\n        \"description\": \"Si concentra sui concetti tecnologici generali, tra cui hardware, modelli di IA e le principali aziende tecnologiche.\"\n      },\n      \"ru\": {\n        \"name\": \"Эксперт по технологиям\",\n        \"description\": \"Фокусируется на общих технологических концепциях, включая оборудование, модели ИИ и крупные технологические компании.\"\n      },\n      \"ko\": {\n        \"name\": \"기술 전문가\",\n        \"description\": \"하드웨어, AI 모델 및 주요 기술 회사를 포함한 일반적인 기술 개념에 중점을 둡니다.\"\n      },\n      \"pt-PT\": {\n        \"name\": \"Especialista em Tecnologia\",\n        \"description\": \"Concentra-se em conceitos gerais de tecnologia, incluindo hardware, modelos de IA e grandes empresas de tecnologia.\"\n      },\n      \"pt-BR\": {\n        \"name\": \"Especialista em Tecnologia\",\n        \"description\": \"Concentra-se em conceitos gerais de tecnologia, incluindo hardware, modelos de IA e grandes empresas de tecnologia.\"\n      },\n      \"tr\": {\n        \"name\": \"Teknoloji Uzmanı\",\n        \"description\": \"Donanım, yapay zeka modelleri ve büyük teknoloji şirketleri dahil olmak üzere genel teknoloji kavramlarına odaklanır.\"\n      }\n    },\n    \"langsHash\": {\n      \"auto\": \"707b8447054abb8726e1e486e3287eeeab7b60d84032968fe4e205fd33d5375f\",\n      \"zh-CN\": \"d7bc8c19113636cbe5e9dc6e6521c1d108797903bf8fe06927e13b76ab66835c\",\n      \"zh-TW\": \"9f30c0ea4c28f1ce88df46936befb978943bb25c1f85bc85355cc33b0b8acaac\"\n    }\n  },\n  {\n    \"id\": \"news\",\n    \"name\": \"News Media Expert\",\n    \"description\": \"Specialized in translating news media content, ensuring accurate and idiomatic translations for news articles, reports, and media-related content.\",\n    \"author\": \"immersive\",\n    \"glossary\": \"news\",\n    \"langs\": [\n      \"zh-CN\",\n      \"zh-TW\"\n    ],\n    \"i18ns\": {\n      \"zh-CN\": {\n        \"name\": \"新闻媒体\",\n        \"description\": \"新闻媒体术语库，包含新闻报道、媒体行业相关术语的中文翻译。\"\n      },\n      \"zh-TW\": {\n        \"name\": \"新聞媒體\",\n        \"description\": \"新聞媒體術語庫，包含新聞報導、媒體行業相關術語的繁體中文翻譯。\"\n      },\n      \"en\": {\n        \"name\": \"News Media Expert\",\n        \"description\": \"Specialized in translating news media content, ensuring accurate and idiomatic translations for news articles, reports, and media-related content.\"\n      }\n    },\n    \"langsHash\": {\n      \"zh-CN\": \"695c7dbea9cd6e08ed58eae80431bfaa0deedee13f2a788de6e96c20fb0195d8\",\n      \"zh-TW\": \"69bcee43c5779d7b3af782b607074024874e5417404c0d637245228c40bbbaef\"\n    }\n  },\n  {\n    \"id\": \"ao3\",\n    \"name\": \"AO3\",\n    \"description\": \"AO3 术语库，包含同人小说、标签、分级、警告等相关术语的中文翻译。\",\n    \"author\": \"immersive\",\n    \"glossary\": \"ao3\",\n    \"lan
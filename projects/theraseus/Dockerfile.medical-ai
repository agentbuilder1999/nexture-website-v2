# Medical AI — Cloud GPU Image
# Target: Linux x86_64 + NVIDIA GPU (CUDA 12.1)
# Usage: docker build -t medical-ai:v1 -f Dockerfile.medical-ai .

FROM nvidia/cuda:12.1.1-cudnn8-devel-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1

# System deps
RUN apt-get update && apt-get install -y \
    python3.11 python3.11-dev python3-pip python3-venv \
    git curl wget libgl1 libglib2.0-0 ffmpeg \
    && rm -rf /var/lib/apt/lists/*

RUN ln -sf /usr/bin/python3.11 /usr/bin/python3 && \
    pip3 install --upgrade pip uv

WORKDIR /workspace

# Core ML stack (GPU)
RUN pip3 install \
    torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cu121

# Copy and install requirements
COPY requirements-medical-ai.txt .
RUN pip3 install -r requirements-medical-ai.txt

# SAM2
RUN pip3 install 'git+https://github.com/facebookresearch/sam2.git'

# Download model weights (uncomment as needed)
# RUN python3 -c "from ultralytics import YOLO; YOLO('yolov8x.pt')"
# RUN wget -q https://dl.fbaipublicfiles.com/segment_anything_2/092824/sam2.1_hiera_tiny.pt
# RUN wget -q https://github.com/xinntao/Real-ESRGAN/releases/download/v0.2.5.0/realesr-general-x4v3.pth

CMD ["bash"]
